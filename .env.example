# Copy to `.env.local` for local dev, or set the same keys in Vercel → Project → Settings → Environment Variables.
# Vite only exposes variables prefixed with VITE_

# Required for app bootstrap (local | development | uat | production)
VITE_APP_ENV=local

# Backend API origin
# - Local: backend on :3000 (or set API_PROXY_TARGET and use /api/v1)
# - Vercel: use /api/v1 — vercel.json proxies to QA API (avoids CORS on *.vercel.app)
# - Direct cross-origin (only if API CORS allows your origin):
#   VITE_API_BASE_URL=https://pnc360-api.qa.aurainsure.ai/api/v1
VITE_API_BASE_URL=http://localhost:3000

# Optional — maps / street view in command center & risk room
# VITE_GOOGLE_MAPS_API_KEY=
